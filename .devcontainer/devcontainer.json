{
    "name": "SQL AI Agent",
    "dockerComposeFile": [
        "../docker-compose.yaml"
    ],
    "service": "python",
    "shutdownAction": "none",
    "workspaceFolder": "/workspace/",
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/opt/sql-ai-agent-dev/bin/python3",
                "python.selectInterpreter": "/opt/sql-ai-agent-dev/bin/python3"
            },
            "extensions": [
                "linkedinlearning.linkedinlearning-vscode-theme",
                // Container
                "ms-azuretools.vscode-docker",
                "ms-vscode-remote.remote-containers",
                //Python
                "ms-python.python",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff",
                // HTML
                "ms-vscode.live-server",
                // Documents/Settings
                "yzhang.markdown-all-in-one",
                "quarto.quarto",
                "redhat.vscode-yaml",
                "ms-toolsai.jupyter",
                "streetsidesoftware.code-spell-checker",
                "tamasfe.even-better-toml",
                "aaron-bond.better-comments",
                "hediet.vscode-drawio",
                //Code
                "oderwat.indent-rainbow",
                // Data
                "mechatroner.rainbow-csv",
                "ms-toolsai.datawrangler",
                "ms-ossdata.vscode-pgsql",
                // Git
                "mhutchie.git-graph",
                // Code
                "continue.continue"
            ]
        }
    },
    // Optional set environment variables:
    "remoteEnv": {
        "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY:key_is_missing}",
        "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY:key_is_missing}",
        "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY:key_is_missing}",
        "POSTGRES_PASSWORD": "${localEnv:POSTGRES_PASSWORD:password}",
        "POSTGRES_USER": "${localEnv:POSTGRES_USER:postgres}",
        "POSTGRES_DB": "${localEnv:POSTGRES_DB:my_db}"
    }
}